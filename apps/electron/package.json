{
  "name": "@opc/electron",
  "version": "0.1.0",
  "description": "OPC Agent Center desktop runtime",
  "author": "OPC Agent Center",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm build && electron .",
