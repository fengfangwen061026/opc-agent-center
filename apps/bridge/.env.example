BRIDGE_PORT=3001
OPENCLAW_MODE=mock
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_DEVICE_NAME=opc-bridge
LANCEDB_PATH=~/.openclaw/memory/lancedb
LANCEDB_MODE=mock
LANCEDB_DB_PATH=~/.openclaw/memory/lancedb
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
MEMORY_AUTO_CAPTURE=true
MEMORY_AUTO_RECALL=true
OBSIDIAN_API_URL=http://localhost:27123
# OBSIDIAN_API_KEY 从环境变量读取，不写入 .env
# OPENCLAW_TOKEN=  # 从 OpenClaw Gateway 配置或环境变量注入；留空时使用 loopback/mock fallback
